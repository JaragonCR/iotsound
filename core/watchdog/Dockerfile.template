FROM balenalib/%%BALENA_MACHINE_NAME%%-debian-python:3.11-run

# Install system dependencies needed for network monitoring
RUN install_packages \
    wireless-tools \
    iproute2 \
    iputils-ping \
    procps

WORKDIR /app

COPY wifi-watchdog.py .
COPY start.sh .
RUN chmod +x /app/start.sh

# Runs privileged via docker-compose for network operations
CMD ["/app/start.sh"]
